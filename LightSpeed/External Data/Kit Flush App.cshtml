@inherits Custom.Hybrid.RazorTyped

@using ToSic.Sxc.Services
@using AppCode.LightSpeed

@{
  var key = "app-flush-demo";

  // This helper page must stay uncached so every action runs on the server.
  Kit.OutputCache.Disable();

  var action = MyPage.Parameters.String("action");
  var touched = (int?)null;
  var actionResult = "No action executed.";

  switch (action)
  {
    case "regenerate":
      var regeneratedOnly = ExternalDataStore.Regenerate(key);
      actionResult = $"Source regenerated to generation {regeneratedOnly.Generation}. Cached app-wide pages stay stale until the app-wide marker is flushed.";
      break;
    case "flush":
      touched = Kit.OutputCacheManagement.Flush(App.AppId);
      actionResult = $"Kit.OutputCacheManagement.Flush(App.AppId) returned {touched}. A return value of 0 is expected for the app-wide flush path.";
      break;
    case "regenerate-flush":
      var regeneratedAndFlushed = ExternalDataStore.Regenerate(key);
      touched = Kit.OutputCacheManagement.Flush(App.AppId);
      actionResult = $"Source regenerated to generation {regeneratedAndFlushed.Generation} and Kit.OutputCacheManagement.Flush(App.AppId) returned {touched}. A return value of 0 is expected for the app-wide flush path.";
      break;
  }

  var snapshot = ExternalDataStore.Get(key);
}

<h1>LightSpeed External Data - Kit Flush App</h1>

<p>
  This page is intentionally uncached and exists to test the Razor API
  <code>Kit.OutputCacheManagement.Flush(App.AppId)</code>.
  Use it together with the cached page <code>App Flush.cshtml</code>.
</p>

<ol>
  <li>Open <code>App Flush.cshtml</code> and note the rendered generation.</li>
  <li>Use <strong>Regenerate Source Only</strong> here to change the external source without invalidating the cached output.</li>
  <li>Use <strong>Flush App Only</strong> or <strong>Regenerate + Flush App</strong> here.</li>
  <li>Reload <code>App Flush.cshtml</code> and verify it now shows the current generation.</li>
</ol>

<p>
  <a href='@Link.To(parameters: MyPage.Parameters.Remove("action"))'>No Action</a>
  |
  <a href='@Link.To(parameters: MyPage.Parameters.Set("action", "regenerate"))'>Regenerate Source Only</a>
  |
  <a href='@Link.To(parameters: MyPage.Parameters.Set("action", "flush"))'>Flush App Only</a>
  |
  <a href='@Link.To(parameters: MyPage.Parameters.Set("action", "regenerate-flush"))'>Regenerate + Flush App</a>
</p>

<dl>
  <dt>Target Cached Page</dt>
  <dd><code>App Flush.cshtml</code></dd>
  <dt>Current Raw Generation</dt>
  <dd>@snapshot.Generation</dd>
  <dt>Current Raw Source Timestamp</dt>
  <dd>@snapshot.GeneratedUtc.ToString("yyyy-MM-dd HH:mm:ss.fff") UTC</dd>
  <dt>Current Raw Display Token</dt>
  <dd>@snapshot.DisplayToken</dd>
  <dt>Flush Return Value</dt>
  <dd>@(touched?.ToString() ?? "n/a")</dd>
  <dt>Last Action Result</dt>
  <dd>@actionResult</dd>
</dl>

@if (!string.IsNullOrEmpty(action))
{
  <script>
    history.replaceState(null, document.title, '@Link.To(parameters: MyPage.Parameters.Remove("action"))');
  </script>
}
